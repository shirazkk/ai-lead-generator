# AI Lead Generation Agent - Environment Variables
# Copy this file to .env and fill in your actual values

# Gemini AI API Key (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Serper API Key for web search (https://serper.dev)
SERPER_API_KEY=your_serper_api_key_here

# Supabase Database
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Resend Email Service (https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# CORS Configuration
# Comma-separated list of allowed origins for frontend
ALLOWED_ORIGINS=http://localhost:3000

# Optional: Application Settings
# PORT=8000
# ENVIRONMENT=development
